{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "deps": "pnpm install",
    "deps:update": "pnpm install && pnpm update --latest",
    "type:check": "tsc -b",
    "build": "tsc -b && vite build",
    "serve": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:ci": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "solid-js": "^1.9.13",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16",
    "vite-plugin-checker": "^0.14.4",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  }
}
