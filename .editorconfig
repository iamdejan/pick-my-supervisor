root = true

[*]
insert_final_newline = true
indent_style = space
trim_trailing_whitespace = true

[*.md]
indent_size = 2

[*.{rs, toml}]
indent_size = 4

[*.{ts,tsx,js,json}]
indent_size = 2
indent_style = space

[Makefile]
indent_size = 4
indent_style = tab

[*.{yml,yaml}]
indent_size = 2
indent_style = space
